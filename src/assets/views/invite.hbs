{{> header title="You're Invited" }}

<div style="background:#FFFFFF;background-color:#FFFFFF;margin:0px auto;max-width:600px;">
  <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation" style="background:#FFFFFF;background-color:#FFFFFF;width:100%;">
    <tbody>
      <tr>
        <td style="direction:ltr;font-size:0px;padding:20px;text-align:center;">
          <div style="font-size:0px;text-align:left;direction:ltr;display:inline-block;vertical-align:top;width:100%;">
            <table border="0" cellpadding="0" cellspacing="0" role="presentation" style="vertical-align:top;" width="100%">
              <tbody>
                <tr>
                  <td align="left" style="word-break:break-word;">
                    <div style="padding:0px 0 10px 0;font-family:Montserrat, Helvetica, Arial, sans-serif;font-size:20px;font-weight:300;line-height:24px;color:#000000;">
                      You've been invited to Agromart!
                    </div>
                  </td>
                </tr>
                <tr>
                  <td align="left" style="word-break:break-word;">
                    <div style="font-family:Montserrat, Helvetica, Arial, sans-serif;font-size:16px;font-weight:300;line-height:24px;text-align:left;color:#282828;">
                      You have been invited to join <strong>Agromart</strong> as a <strong>{{role}}</strong>.
                      Click the button below to complete your registration. This invitation expires in <strong>48 hours</strong>.
                    </div>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding:30px 0 20px 0;">
                    <a href="{{inviteLink}}"
                      style="background:#F19136;color:#FFFFFF;font-family:Montserrat, Helvetica, Arial, sans-serif;font-size:16px;font-weight:600;text-decoration:none;padding:14px 32px;border-radius:8px;display:inline-block;">
                      Accept Invitation
                    </a>
                  </td>
                </tr>
                <tr>
                  <td align="left" style="word-break:break-word;">
                    <div style="font-family:Montserrat, Helvetica, Arial, sans-serif;font-size:13px;font-weight:300;line-height:20px;color:#888888;">
                      Or copy this link: <a href="{{inviteLink}}" style="color:#F19136;">{{inviteLink}}</a>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td align="left" style="padding-top:20px;word-break:break-word;">
                    <div style="font-family:Montserrat, Helvetica, Arial, sans-serif;font-size:14px;font-weight:300;line-height:24px;color:#282828;">
                      If you were not expecting this invitation, you can safely ignore this email.
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </td>
      </tr>
    </tbody>
  </table>
</div>

{{> footer }}
